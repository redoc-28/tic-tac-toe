{
  "compilerOptions": {
    "target": "ES2020",
    "module": "None",
    "lib": ["ES2020"],
    "outDir": "./build",
    "rootDir": "./modules",
    "strict": true,
    "esModuleInterop": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "classic",
    "resolveJsonModule": false,
    "declaration": false
  },
  "include": ["modules/**/*", "global.d.ts"],
  "exclude": ["node_modules", "build"]
}
